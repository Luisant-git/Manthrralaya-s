generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User roles enum
enum UserRole {
  RECEPTIONIST
  DOCTOR
  ADMIN
  THERAPIST
}

// User model for authentication
model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  username  String ?   @unique 
  pin       String
  role      UserRole 
  fullName  String?
  phone     String?
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  doctor    Doctor?  

  @@map("users")
}

model Doctor {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  specialization String
  status         String   @default("Available")
  user           User     @relation(fields: [userId], references: [id])

  appointments   Appointment[]
  consultations  Consultation[]
  detoxConsultations Consultation[] @relation("DetoxDoctor")
  detoxSessions   DetoxSession[] 


  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Patient {
  id            Int      @id @default(autoincrement())
  name          String
  age           Int
  gender        String?
  phone         String   @unique
  whatsapp      String?
  location      String?
  address       String?
  createdAt     DateTime @default(now()) 
  updatedAt     DateTime @updatedAt 

  appointments  Appointment[]
  consultations Consultation[]
  receptionistFollowups ReceptionistFollowup[]
  detoxSessions  DetoxSession[]  

  @@map("patients")
  @@index([phone])
}

model Appointment {
  id              Int       @id @default(autoincrement())
  patientId       Int       
  doctorId        Int?      
  appointmentDate DateTime 
  appointmentType String    
  session         String    @default("FN")
  status          String    @default("Scheduled")
  notes           String? 
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt 

  patient         Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          Doctor?   @relation(fields: [doctorId], references: [id])
  consultation    Consultation?
  detoxSessions   DetoxSession[] 

  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentDate])
  @@index([status])
}

model Consultation {
  id                Int       @id @default(autoincrement())
  patientId         Int
  doctorId          Int
  appointmentId     Int?      @unique
  consultationDate  DateTime  @default(now())
  
  // Consultation fields
  consultationNotes String?
  medicalHistoryNotes    String?
  detoxProcedureNotes    String?
  dietPlanNotes     String?
  homecareGuideliness String?
  
  // Detox recommendation fields
  detoxRecommended  Boolean   @default(false)
   detoxDoctorId     Int?      // Reference to the recommended detox doctor
  followupDate      DateTime?
  followupRemarks   String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  patient           Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor            Doctor    @relation(fields: [doctorId], references: [id])
  appointment       Appointment? @relation(fields: [appointmentId], references: [id])
  detoxDoctor       Doctor?   @relation("DetoxDoctor", fields: [detoxDoctorId], references: [id])
  detoxSessions     DetoxSession[] 
  receptionistFollowup ReceptionistFollowup?

  @@index([patientId])
  @@index([doctorId])
  @@index([detoxDoctorId])
  @@index([appointmentId])
  @@index([consultationDate])
}

model DetoxSession {
  id              Int       @id @default(autoincrement())
  patientId       Int
  doctorId        Int?
  appointmentId   Int?
  consultationId  Int?
  
  // Session details
  sessionNumber   Int       // 1, 2, or 3 (max 3 sessions per patient)
  sessionType     String    // 'morning', 'evening', 'fullDay'
  sessionDate     DateTime  @default(now())
  
  // Detox notes
  detoxNotes      String?   
  
  // Follow-up details
  followupDate    DateTime?
  followupRemarks String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  patient         Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          Doctor?   @relation(fields: [doctorId], references: [id])
  appointment     Appointment? @relation(fields: [appointmentId], references: [id]) // Removed @unique
  consultation    Consultation? @relation(fields: [consultationId], references: [id])


  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentId])
  @@index([consultationId])
  @@index([sessionDate])
}

model ReceptionistFollowup {
  id             Int      @id @default(autoincrement())
  consultationId Int      @unique
  patientId      Int
  followupDate   DateTime?
  notes          String?    @db.Text
  status         String    @default("Pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  consultation Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id])

  @@map("receptionist_followups")
}